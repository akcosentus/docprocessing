# OpenAI API Configuration
OPENAI_API_KEY=your_api_key_here
OPENAI_ORG_ID=your_org_id_here

# Logging Configuration
LOG_LEVEL=INFO

# Model Configuration
MODEL_SNAPSHOT=gpt-4o-2024-11-20

# File Processing Configuration
MAX_FILE_SIZE_MB=50

# Excel Output Configuration
# Optional: defaults to ~/Desktop/PatientDemographics/PatientDemographics.xlsx
OUTPUT_EXCEL=

# Consistency Check Configuration
# Optional: defaults to 0.85. Empirically, scores below this threshold correlate with
# documents where OCR quality is poor or form layout is ambiguous
CONSISTENCY_THRESHOLD=0.85
